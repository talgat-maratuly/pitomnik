# Pitomnik monorepo — переменные окружения
# Локально: cp .env.example .env && cp apps/api/.env.example apps/api/.env

# Frontend (apps/web/.env) — см. apps/web/.env.example
# Backend (apps/api/.env) — см. apps/api/.env.example

# Database Configuration (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=pitomnik

# Server & URLs
PORT=3001
FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3001
DB_MIGRATE=true

# Auth
JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# OpenAI AI assistants
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_VISION_MODEL=gpt-4o
OPENAI_ADMIN_MODEL=gpt-4o
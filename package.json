{
  "name": "pitomnik-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:api": "npm run start:dev -w @pitomnik/api",
    "dev:web": "npm run dev -w @pitomnik/web",
    "build": "npm run build:api && npm run build:web",
    "build:api": "npm run build -w @pitomnik/api",
    "build:web": "npm run build -w @pitomnik/web",
    "migration:run": "npm run migration:run -w @pitomnik/api",
    "migration:revert": "npm run migration:revert -w @pitomnik/api",
    "seed": "npm run seed -w @pitomnik/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

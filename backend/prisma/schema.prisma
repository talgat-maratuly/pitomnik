generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Object {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  sections    Section[]

  @@map("objects")
}

model Section {
  id           Int       @id @default(autoincrement())
  objectId     Int       @map("object_id")
  code         String    @unique
  name         String
  area         String?
  culture      String?
  customText   String?   @map("custom_text")
  qrCodeUrl    String?   @map("qr_code_url")
  formUrl      String?   @map("form_url")
  latitude     Float?
  longitude    Float?
  radiusMeters Int?      @map("radius_meters")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  object       Object    @relation(fields: [objectId], references: [id], onDelete: Cascade)
  workLogs     WorkLog[]

  @@map("sections")
}

model WorkType {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  isActive  Boolean   @default(true) @map("is_active")
  isOther   Boolean   @default(false) @map("is_other")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  workLogs  WorkLog[]

  @@map("work_types")
}

model WorkLog {
  id               Int       @id @default(autoincrement())
  sectionId        Int       @map("section_id")
  workerFullName   String    @map("worker_full_name")
  workTypeId       Int?      @map("work_type_id")
  customWorkType   String?   @map("custom_work_type")
  workVolume       String    @map("work_volume")
  comment          String    @default("")
  photoUrls        String    @default("[]") @map("photo_urls")
  latitude         Float?
  longitude        Float?
  locationAccuracy Float?    @map("location_accuracy")
  locationAllowed  Boolean   @default(false) @map("location_allowed")
  submittedAt      DateTime  @default(now()) @map("submitted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  section          Section   @relation(fields: [sectionId], references: [id])
  workType         WorkType? @relation(fields: [workTypeId], references: [id])

  @@index([submittedAt])
  @@index([workerFullName])
  @@map("work_logs")
}

model SectionCodeCounter {
  id    Int @id @default(1)
  value Int @default(0)

  @@map("section_code_counter")
}
